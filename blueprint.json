{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/repo-pop-demo/",
  "preferredVersions": {
    "php": "8.4",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/RegionallyFamous/repo-pop",
        "ref": "main",
        "refType": "branch"
      },
      "options": {
        "activate": true,
        "targetFolderName": "repo-pop"
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once('/wordpress/wp-load.php'); $repo = 'https://github.com/WordPress/gutenberg'; $content = '<!-- wp:heading {\"level\":2} --><h2>Hero Stack</h2><!-- /wp:heading --><!-- wp:repo-pop/repository {\"repoUrl\":\"' . esc_url_raw($repo) . '\",\"layout\":\"hero-stack\"} /--><!-- wp:heading {\"level\":2} --><h2>Bento Board</h2><!-- /wp:heading --><!-- wp:repo-pop/repository {\"repoUrl\":\"' . esc_url_raw($repo) . '\",\"layout\":\"bento-board\"} /--><!-- wp:heading {\"level\":2} --><h2>Terminal Zine</h2><!-- /wp:heading --><!-- wp:repo-pop/repository {\"repoUrl\":\"' . esc_url_raw($repo) . '\",\"layout\":\"terminal-zine\"} /-->'; $existing = get_page_by_path('repo-pop-demo'); $post = array('post_title' => 'Repo Pop Demo', 'post_name' => 'repo-pop-demo', 'post_type' => 'page', 'post_status' => 'publish', 'post_content' => $content); if ($existing) { $post['ID'] = $existing->ID; wp_update_post($post); } else { wp_insert_post($post); } update_option('permalink_structure', '/%postname%/'); flush_rewrite_rules();"
    }
  ]
}
